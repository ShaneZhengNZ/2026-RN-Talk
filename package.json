{
  "name": "rn-talk",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "dep:check": "syncpack lint",
    "dep:fix": "syncpack fix-mismatches && syncpack format",
    "knip": "knip",
    "lint": "biome check . && bun --filter '@rn-talk/mobile' lint",
    "lint:fix": "biome check . --write",
    "format": "biome format . --write"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.14",
    "knip": "^5.86.0",
    "syncpack": "14.2.0",
    "turbo": "^2.3.0",
    "typescript": "~5.9.2"
  },
  "packageManager": "bun@1.3.14",
  "engines": {
    "bun": ">=1.3.0",
    "node": ">=22.11.0"
  },
  "volta": {
    "node": "24.15.0"
  }
}
